# BING SENTIMENT ANALYSIS
# The BING lexicon classifies words either positive or negative

# The words of George Orwell's 1984 are matched with the Bing dictionary
# Words not found in the dictionary are excluded

# Loading the BING sentiment analysis
bing <- get_sentiments("bing")

# Matching words from the datatset to the BING lexicon
bing_sentiment_words <- clean_words_1984 %>%
  inner_join(bing, by = "word")

bing_summary <- bing_sentiment_words %>%
  count(sentiment) %>%
  mutate(percent = n / sum(n))

# Creating an overview of whether the dataset contains more positive or negative words
print(bing_summary)

# Visualizing the summary
# The following plot displays the positive and negative sentiment of the dataset
BING_sentiment_1984 <- bing_summary %>%
  ggplot(aes(x = sentiment, y = n, fill = sentiment)) +
  geom_col(show.legend = FALSE) +
  geom_text(
    aes(label = paste0(n, " words\n", percent(percent, accuracy = 1))),
    vjust = -0.3
  ) +
  scale_fill_manual(values = c(
    "negative" = "#D00000",
    "positive" = "#0057D9"
  )) +
  labs(
    title = "Positive and Negative Sentiment in George Orwell's 1984",
    subtitle = "The BING lexicon",
    x = NULL,
    y = "Number of sentiment words"
  ) +
  theme_minimal()

# Displaying the visualization
BING_sentiment_1984

# Saving the ggplot
ggsave(
  "BING_sentiment_1984.png",
  plot = BING_sentiment_1984,
  width = 8,
  height = 12,
  dpi = 300
)

# Looking into the most common positive and negative words of 1984
# The following plot displays which specific positive and negative words appear most often
common_words_1984 <- bing_sentiment_words %>%
  count(word, sentiment, sort = TRUE) %>%
  group_by(sentiment) %>%
  slice_max(n, n = 12, with_ties = FALSE) %>%
  ungroup() %>%
  mutate(word = reorder_within(word, n, sentiment)) %>%
  ggplot(aes(x = word, y = n, fill = sentiment)) +
  geom_col(show.legend = FALSE) +
  coord_flip() +
  facet_wrap(~ sentiment, scales = "free_y") +
  scale_x_reordered() +
  scale_fill_manual(values = c(
    "negative" = "#D00000",
    "positive" = "#0057D9"
  )) +
  labs(
    title = "The most common Positive and Negative Words in George Orwell's 1984",
    x = NULL,
    y = "Frequency"
  ) +
  theme_minimal()

# Displaying the visualization
common_words_1984

# Saving the plot
ggsave(
  "common_words_1984.png",
  plot = common_words_1984,
  width = 8,
  height = 6,
  dpi = 300
)

# _________________________________________________

# Creating a sentiment wordcloud
# The wordcloud includes words which the BING lexicon recognizes as sentiment words
# The red words are recognized as negative and the blue words are recognized as positive
# The size of each word represent the frequency of occurance

#Counting how often each sentiment word appears
sentiment_freq <- bing_sentiment_words %>%
  count(word, sentiment, sort = TRUE)

# Assigning colors based on sentiment classification
word_colors <- ifelse(
  sentiment_freq$sentiment == "positive",
  "#0057D9",
  "#D00000"
)


# Saving the wordcloud as a PNG.file
png(
  "BING_sentiment_wordcloud_1984.png",
  width = 1200,
  height = 1000,
  res = 150
)

# Creating the sentiment wordcloud
wordcloud(
  words = sentiment_freq$word,
  freq = sentiment_freq$n,
  max.words = 250,
  random.order = FALSE,
  rot.per = 0.15,
  scale = c(5, 0.5),
  colors = word_colors,
  family = "serif"
)

# Creating a legend to help accentuate the representation of the colors
legend(
  "topright",
  legend = c("Positive", "Negative"),
  col = c("#0057D9", "#D00000"),
  pch = 15,
  cex = 1
)

# Finishing off and saving the PNG.file
dev.off()

