# AFINN SENTIMENT ANALYSIS
# The AFINN lexicon assigns each word a numerical sentiment score
# The following code inspects the significance of sentiment of each word

# Matching cleaned words from George Orwell's 1984 with the AFINN lexicon
afinn_scores <- orwell_words_clean %>%
  inner_join(get_sentiments("afinn"), by = "word")

# Counting the amount of words with each sentiment score
# Ranking from the most negative words to the most positive words
afinn_ranking <- afinn_scores %>%
  count(value, sort = TRUE)

# Converting value to factor
afinn_ranking$value <- as.factor(afinn_ranking$value)

# Printing th full ranking allowing direct inspection of the sentiment distribution
print(afinn_ranking)

# Creating the visualization showing the sentiment scores of George Orwell's 1984
sentiment_scores_1984 <- ggplot(afinn_ranking, aes(x = factor(value), y = n, fill = value)) +
  geom_col() +
  scale_fill_manual(values = c(
    "-5" = "#5C0000",   # darkest red
    "-4" = "#8B0000",   # dark red
    "-3" = "#B22222",   # firebrick red
    "-2" = "#D00000",   # strong red
    "-1" = "#FF4D4D",   # lighter red
    "0"  = "#D9D9D9",   # neutral grey
    "1"  = "#B3D9FF",   # light blue
    "2"  = "#66B2FF",   # brighter blue
    "3"  = "#1E90FF",   # strong blue
    "4"  = "#0057D9",   # cobalt blue
    "5"  = "#0038A8"    # dark blue
  )) +
  labs(
    title = "AFINN Sentiment Score Distribution in George Orwell's 1984",
    subtitle = "Ranking words by sentiment score from negative (-5) to positive (+5)",
    x = "Sentiment Score",
    y = "Word Count"
  ) +
  theme_minimal()

# Displaying the visualization
sentiment_scores_1984

# Saving the visualization
ggsave(
  "sentiment_scores_1984.png",
  plot = sentiment_scores_1984,
  width = 8,
  height = 6,
  dpi = 300
)

# The following section calculates the average sentiment score of the text
afinn_scores %>%
  summarise(
    Mean = mean(value),
    Median = median(value),
    Minimum = min(value),
    Maximum = max(value)
  )

