# Investigating the AFINN sentiment scores
# The following section focuses specifically on words given the AFINN sentiment score of -2, since it is the most common of the dataset
# By isolating these words, it becomes easier to inspect and understand which specififc terms help create the dystopian atmosphere in George Orwell's 1984

# Filtering the score of interest
# Counting the frequency of each word
# Sorting them from most frequent to least frequent
minus2_words <- afinn_scores %>%
  filter(value == -2) %>%
  count(word, sort = TRUE)

# Printing the full list to inspect the words of the sentiment score
print(minus2_words)

# Creating the visualization displaying the most frequent words of the AFINN sentiment score
AFINN_minus2_1984 <- minus2_words %>%
