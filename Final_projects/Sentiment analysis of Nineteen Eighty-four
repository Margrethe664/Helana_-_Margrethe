# SENTIMENT ANALYSIS OF GEORGE ORWELL'S Nineteen Eighty-four
# Authors: Helena Hymøller Jensen and Cecilie Margrethe Nielsen

# Introduction
# The following script does text mining and sentiment analysis on George Orwell's dystopian novel Nineteen Eighty-four
# We've decided to use three sentiment lexicons, which includes: 
  # Bing: which classifies words as either positive and negative
  ## NRC: which classifies words into emotions
  ### AFINN: which gives words a numerical sentiment score from negative to positive


# Installing packages:
install.packages(c(
  "readtext",
  "tidyverse",
  "tidytext",
  "stringr",
  "ggplot2",
  "scales",
  "wordcloud",
  "wordcloud2",
  "RColorBrewer"
))

# Loading libraries
library(readtext)
library(tidyverse)
library(tidytext)
library(stringr)
library(ggplot2)
library(scales)
library(wordcloud)
library(wordcloud2)
library(dplyr)
library(RColorBrewer)

# _________________________________________________

# Importing the entirety of George Orwell's 1984
# The following code readtext() imports the document, and code tibble() converts it into a tidy data frame

file_path <- "data/1984.docx"

text_data <- readtext(file_path)

data_1984 <- tibble(
  text = text_data$text
)

# _________________________________________________

# Cleaning and tokenizing the dataset for further analysis

# Removing line breaks and extra spaces
# Converting uppercase words into lowercase words
clean_1984 <- data_1984 %>%
  mutate(
    text = text %>%
      str_replace_all("\\n", " ") %>%
      str_replace_all("\\s+", " ") %>%
      str_to_lower() %>%
      str_trim()
  )

# Splitting the text into individual words by tokenizing the datatset
words_1984 <- clean_1984 %>%
  unnest_tokens(word, text)

# Removing common words lacking deeper meaning
data("stop_words")

# Removing numbers and very short words lacking deeper meaning
clean_words_1984 <- words_1984 %>%
  anti_join(stop_words, by = "word") %>%
  filter(!str_detect(word, "^[0-9]+$")) %>%
  filter(str_length(word) > 2)

# _________________________________________________

# Looking into the frequency of words by counting how often each word appear in the dataset
# Word Frequency can help identify repeated themes, names and concepts
word_freq_1984 <- clean_words_1984 %>%
  count(word, sort = TRUE)

# Looking into the twenty-five most frequent words in George Orwell's 1984
head(word_freq_1984, 25)

# Plotting the the twenty-five most frequent words in George Orwell's 1984
The_twentyfive_most_frequent_words_1984 <- word_freq_1984 %>%
  slice_max(n, n = 25) %>%
  mutate(word = reorder(word, n)) %>%
  ggplot(aes(x = word, y = n)) +
  geom_col(fill = "#D00000") +
  coord_flip() +
  labs(
    title = "The twenty-five most frequent words in George Orwell's 1984",
    x = NULL,
    y = "Frequency"
  ) +
  theme_minimal()

The_twentyfive_most_frequent_words_1984

# Saving the visualization
ggsave(
  "The_twentyfive_most_frequent_words_1984.png",
  plot = The_twentyfive_most_frequent_words_1984,
  width = 8,
  height = 6,
  dpi = 300
)

# Creating a Wordcloud visualizing the most frequent words in George Orwell's 1984"
# Higher word frequency means stronger visual emphasis

# The first section prepares the data for the word cloud
# The first hundred most frequent words are selected from the dataset, and are assigned a color based on how often it appears
wordcloud_data <- word_freq %>%
  slice_max(n, n = 100) %>%
  mutate(
    color = case_when(
      n < 50 ~ "#666666",      # Below 100 = dark grey
      n < 100 ~ "#000000",      # 100–149 = black
      n < 150 ~ "#FFD60A",      # 150–199 = yellow
      n < 200 ~ "#D00000",      # 200–249 = bright red
      n < 250 ~ "#D4A017",      # 250–299 = mustard
      n < 300 ~ "#1D4ED8",      # 300–349 = cobalt blue
      TRUE ~ "#0038A8"          # 350+ = dark blue
    )
  )

# Creating a wordcloud using wordcloud2
# The word frequency is displayed through both size and color
wordcloud_1984 <- wordcloud2(
  data = wordcloud_data[, c("word", "n")],
  color = wordcloud_data$color,
  size = 0.8,
  backgroundColor = "white"
)

# Displaying he visualization
wordcloud_1984

# Saving the visualization
library(htmlwidgets)
saveWidget(
  wordcloud_1984,
  "wordcloud_1984.html",
  selfcontained = TRUE
)

